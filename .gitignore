# Claude Code writes machine-local overrides here; never track them.
.claude/settings.local.json

# Never track anything resembling Claude credentials or session state.
claude/.credentials.json
claude/history.jsonl
claude/projects/
claude/sessions/
claude/shell-snapshots/

# install.sh backups
*.bak.*

# Plaintext secrets never belong in git -- only their ansible-vault
# encrypted counterparts under keys/ and ssh/ are tracked.
/phonecheck.zsh
